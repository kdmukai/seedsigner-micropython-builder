FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y \
    git make cmake ninja-build ccache rsync \
    python3 python3-venv python3-pip \
    libffi-dev libssl-dev libpng-dev \
    dfu-util libusb-1.0-0 libsdl2-2.0-0 libslirp0 \
    sudo ca-certificates curl && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /workspace/seedsigner-micropython-builder

# Intended usage:
# docker run --rm -it -v <builder-root>:/workspace/seedsigner-micropython-builder \
#   seedsigner-micropython-builder-dev bash

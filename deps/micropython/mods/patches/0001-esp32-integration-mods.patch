+  set(_mp_net_val "$ENV{MICROPY_DISABLE_NETWORK}")
+endif()
+string(TOUPPER "${_mp_net_val}" _mp_net_val)
+if(_mp_net_val STREQUAL "ON" OR _mp_net_val STREQUAL "1" OR _mp_net_val STREQUAL "TRUE" OR _mp_net_val STREQUAL "Y")
+  set(_MICROPY_NET_OFF TRUE)
+endif()
+message(STATUS "MICROPY_DISABLE_NETWORK=${MICROPY_DISABLE_NETWORK} ENV{MICROPY_DISABLE_NETWORK}=$ENV{MICROPY_DISABLE_NETWORK} _MICROPY_NET_OFF=${_MICROPY_NET_OFF}")

@@ -63,7 +63,12 @@
 #include "usb_serial_jtag.h"
 #include "modesp32.h"
 #include "modmachine.h"
+// modnetwork.h drags in esp_wifi_types.h/esp_netif.h, whose components are
+// absent in offline builds (MICROPY_DISABLE_NETWORK). main.c only needs it
+// for socket_events_deinit(), which is MICROPY_PY_SOCKET_EVENTS-guarded.
+#if MICROPY_PY_NETWORK || MICROPY_PY_SOCKET_EVENTS
 #include "modnetwork.h"
+#endif
 
 #if MICROPY_BLUETOOTH_NIMBLE
 #include "extmod/modbluetooth.h"
diff --git a/ports/esp32/main/CMakeLists.txt b/ports/esp32/main/CMakeLists.txt
index 40188abff..6c1f5d855 100644
--- a/ports/esp32/main/CMakeLists.txt
+++ b/ports/esp32/main/CMakeLists.txt
@@ -8,4 +8,18 @@ if(NOT MICROPY_PORT_DIR)
     get_filename_component(MICROPY_PORT_DIR ${MICROPY_DIR}/ports/esp32 ABSOLUTE)
 endif()
 
+# Pull in external display stack + camera (scan + entropy) components from
+# EXTRA_COMPONENT_DIRS. None is reached via the IDF requires graph (the usermod
+# links them post-hoc), so all must be force-included here to be compiled.
+# esp-secp256k1 (native libsecp256k1) and esp-hashlib-ext (mbedtls SHA-512 +
+# PBKDF2) are the same case: the usermod links __idf_esp-secp256k1 /
+# __idf_esp-hashlib-ext post-hoc, so force-include them to get compiled.
+list(APPEND IDF_COMPONENTS display_manager camera_scanner camera_entropy cUR esp-secp256k1 esp-hashlib-ext)
+
+# NOTE: do NOT set EXCLUDE_COMPONENTS here. It is only honored at project
+# level before project.cmake is included — the network-strip exclusion lives
+# in ports/esp32/CMakeLists.txt (see MICROPY_DISABLE_NETWORK there). A copy
+# set in this file runs after component discovery and is silently ignored
+# (which is why the original network-strip attempt never worked).
+
 include(${MICROPY_PORT_DIR}/esp32_common.cmake)

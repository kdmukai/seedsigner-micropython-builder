+# Optional extra sdkconfig fragment appended LAST (so it overrides everything
+# in the board chain). The builder uses this for its build profiles, e.g.
+# PROFILE=release -> sdkconfig.seedsigner_release (SPIRAM memtest off, log
+# levels down). Semicolon-separated list of absolute paths.
+if(DEFINED MICROPY_SDKCONFIG_EXTRA)
+    foreach(_extra_sdkconfig ${MICROPY_SDKCONFIG_EXTRA})
+        if(EXISTS "${_extra_sdkconfig}")
+            list(APPEND SDKCONFIG_DEFAULTS "${_extra_sdkconfig}")
+        else()
+            message(WARNING "MICROPY_SDKCONFIG_EXTRA entry not found: ${_extra_sdkconfig}")
+        endif()
+    endforeach()
+endif()
+
 # Concatenate all sdkconfig files into a combined one for the IDF to use.
 file(WRITE ${CMAKE_BINARY_DIR}/sdkconfig.combined.in "")
 foreach(SDKCONFIG_DEFAULT ${SDKCONFIG_DEFAULTS})
@@ -58,6 +72,58 @@ endforeach()
 configure_file(${CMAKE_BINARY_DIR}/sdkconfig.combined.in ${CMAKE_BINARY_DIR}/sdkconfig.combined COPYONLY)
 set(SDKCONFIG_DEFAULTS ${CMAKE_BINARY_DIR}/sdkconfig.combined)
 
+
+# Allow external ESP-IDF component directories when explicitly provided by builder/scripts.
+# Accepts a semicolon-separated list of paths (CMake list convention).
+if(DEFINED MICROPY_EXTRA_COMPONENT_DIRS)
+    foreach(_ext_comp_dir ${MICROPY_EXTRA_COMPONENT_DIRS})
+        if(EXISTS "${_ext_comp_dir}")
+            list(APPEND EXTRA_COMPONENT_DIRS "${_ext_comp_dir}")
+        else()
+            message(WARNING "MICROPY_EXTRA_COMPONENT_DIRS entry not found: ${_ext_comp_dir}")
+        endif()
+    endforeach()
+endif()
+
+# Offline firmware (MICROPY_DISABLE_NETWORK): exclude the entire radio/TCP-IP
+# component tree from component DISCOVERY. This is the only place
+# EXCLUDE_COMPONENTS is honored — it must be set at project level BEFORE
+# project.cmake is included (a copy set inside a component CMakeLists, e.g.
+# main/, runs after discovery and is silently ignored). Detection mirrors
+# esp32_common.cmake: the -D cache arg plus the environment-variable fallback
+# (script-mode passes can't see the cache).
+# NOTE: esp_netif / lwip / esp_netif_stack can only be excluded because the
+# builder patches the tinyusb managed component to drop its USB networking
+# classes and their esp_netif requirement (component_patches/tinyusb-*.patch);
+# excluding a component that a kept component still REQUIRES fails configure.
+set(_mp_proj_net_off "${MICROPY_DISABLE_NETWORK}")
+if(NOT _mp_proj_net_off AND DEFINED ENV{MICROPY_DISABLE_NETWORK})
+    set(_mp_proj_net_off "$ENV{MICROPY_DISABLE_NETWORK}")
+endif()
+if(_mp_proj_net_off)
+    list(APPEND EXCLUDE_COMPONENTS
+        # radio + TCP/IP core
+        esp_wifi esp_netif esp_netif_stack lwip esp_eth bt esp_hid
+        wpa_supplicant esp_coex ieee802154 openthread
+        # TLS/HTTP/OTA/provisioning application stacks
+        esp-tls esp_http_client esp_http_server esp_https_server esp_https_ota
+        tcp_transport mqtt protocomm protobuf-c http_parser
+        wifi_provisioning esp_local_ctrl
+        # managed network components (defensive: excluded even if a future
+        # manifest change re-adds them)
+        espressif__mdns espressif__esp_hosted espressif__esp_wifi_remote
+        espressif__eppp_link espressif__esp_serial_slave_link
+    )
+endif()
+# NOTE on the I/O expander (TCA9554): its per-board disable is handled
+# entirely in board_common (manifest `require: no` + a BOARD_HAS_IO_EXPANDER-
+# conditional REQUIRE). Do NOT try to EXCLUDE_COMPONENTS it here — components
+# fetched by the IDF component manager are re-added by the manager's own
+# integration and bypass EXCLUDE_COMPONENTS (verified empirically); the entry
+# would be dead machinery that looks load-bearing. As an unreferenced,
+# unlinked orphan it contributes zero bytes to the image.
+message(STATUS "PROJECT_EXCLUDE_COMPONENTS=${EXCLUDE_COMPONENTS}")
+
 # Include main IDF cmake file.
 include($ENV{IDF_PATH}/tools/cmake/project.cmake)
 
